    methodName(arguments);


#Strings – Syntax
String Declaration
  String str = "Hello";
String Methods
    length()
    str.length();
    charAt()
    str.charAt(index);
    substring()
    str.substring(beginIndex, endIndex);
    equals()
    str1.equals(str2);
    equalsIgnoreCase()
    str1.equalsIgnoreCase(str2);
    compareTo()
    str1.compareTo(str2);
    toUpperCase()
    str.toUpperCase();
    toLowerCase()
    str.toLowerCase();
    trim()
    str.trim();
    contains()
    str.contains("text");
    startsWith()
    str.startsWith("text");
    endsWith()
    str.endsWith("text");
    indexOf()
    str.indexOf("text");
    lastIndexOf()
    str.lastIndexOf("text");
    replace()
    str.replace(oldChar, newChar);    
    or    
    str.replace("old", "new");
    concat()
    str.concat("text");
    isEmpty()
    str.isEmpty();
    split()
    str.split("delimiter");

