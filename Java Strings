class Solution {
    public boolean isPalindrome(String s) {
       //	String s="A man, a plan, a canal: Panama";
        s=s.toLowerCase();
        //System.out.println(ls);
        char[] c=s.toCharArray();
        int j=0;
        for(int i=0;i<c.length;i++){
            if(c[i]>=97 && c[i]<=122 || c[i]>=48 && c[i]<=57 ){
              c[j]=c[i];
              j++;
            }
        }
        int left=0;
        int right=j-1;
        while(left<right){
            if(c[left]==c[right]){
               left++;
               right--;
            }
            else
              return false;
        }
        return true;
    }
}










